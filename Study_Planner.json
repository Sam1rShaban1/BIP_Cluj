        "promptType": "define",
        "text": "={{ $('save_report').first().json.report }}",
        "options": {
          "systemMessage": "/no_think\nYou extract scheduled study sessions from a study plan. Read the plan and return ONLY a JSON array, no prose, no code fences. Each element: {\"day\":\"Monday\",\"start\":\"HH:MM\",\"end\":\"HH:MM\",\"title\":\"short label\"}. Use 24-hour times. Use the weekday names exactly as Monday..Sunday. Include only concrete study sessions with a day and a start time; ignore deadlines, milestones and prose. If none are found, return []."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        4960,
        -128
      ],
      "id": "ecb5fc88-5236-4368-a74d-10034b18861a",
      "name": "ics_agent"
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst dir = '/data/flagged';\nfs.mkdirSync(dir, { recursive: true });\n\nfunction extractArray(raw) {\n  let s = String(raw)\n    .replace(/<\\|?[a-z_]+\\|?>/gi, '')\n    .replace(/```[a-z]*\\n?/gi, '').replace(/```/g, '');\n  try { const v = JSON.parse(s); if (Array.isArray(v)) return v; } catch {}\n  const i = s.indexOf('['), j = s.lastIndexOf(']');\n  if (i !== -1 && j > i) { try { const v = JSON.parse(s.slice(i, j + 1)); if (Array.isArray(v)) return v; } catch {} }\n  return [];\n}\n\nconst DOW = { sunday:0, monday:1, tuesday:2, wednesday:3, thursday:4, friday:5, saturday:6 };\nconst pad = n => String(n).padStart(2, '0');\n\nfunction nextDateForDow(dow) {\n  const now = new Date();\n  const delta = (dow - now.getDay() + 7) % 7;\n  return new Date(now.getFullYear(), now.getMonth(), now.getDate() + delta);\n}\nfunction fmt(d, hhmm) {\n  const [h, m] = String(hhmm || '09:00').split(':').map(x => parseInt(x, 10) || 0);\n  return `${d.getFullYear()}${pad(d.getMonth()+1)}${pad(d.getDate())}T${pad(h)}${pad(m)}00`;\n}\nfunction esc(t) {\n  return String(t || 'Study session')\n    .replace(/\\\\/g,'\\\\\\\\').replace(/;/g,'\\\\;').replace(/,/g,'\\\\,').replace(/\\r?\\n/g,'\\\\n');\n}\n\nconst raw = $json.output ?? $json.text ?? '';\nconst events = extractArray(raw).filter(e => e && e.day && e.start);\n\nconst src  = $('save_report').first().json;\nconst name = src.name || 'student';\n\nconst now = new Date();\nconst dtstamp = `${now.getUTCFullYear()}${pad(now.getUTCMonth()+1)}${pad(now.getUTCDate())}T${pad(now.getUTCHours())}${pad(now.getUTCMinutes())}${pad(now.getUTCSeconds())}Z`;\n\nconst lines = ['BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Study Planner//EN','CALSCALE:GREGORIAN','METHOD:PUBLISH'];\nevents.forEach((e, idx) => {\n  const key = String(e.day).trim().toLowerCase();\n  if (!(key in DOW)) return;\n  const d = nextDateForDow(DOW[key]);\n  lines.push(\n    'BEGIN:VEVENT',\n    `UID:study-${idx}-${Date.now()}@study-planner`,\n    `DTSTAMP:${dtstamp}`,\n    `DTSTART:${fmt(d, e.start)}`,\n    `DTEND:${fmt(d, e.end || e.start)}`,\n    'RRULE:FREQ=WEEKLY;COUNT=12',\n    `SUMMARY:${esc(e.title)}`,\n    'END:VEVENT'\n  );\n});\nlines.push('END:VCALENDAR');\nconst ics = lines.join('\\r\\n') + '\\r\\n';\n\nconst safeName = String(name).replace(/[^a-z0-9]+/gi,'_').toLowerCase();\nconst stamp = new Date().toISOString().slice(0,19).replace(/[:T]/g,'-');\nconst path = `${dir}/plan-${safeName}-${stamp}.ics`;\nfs.writeFileSync(path, ics);\n\nreturn [{ json: { ics_saved: path, events: events.length, report: src.report, name, saved: src.saved } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        5312,
        -128
      ],
      "id": "c50f8ae0-f436-40cd-aaa5-f071425fcc8e",
      "name": "build_ics"
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\n\n// Pull the generated content from build_ics BY NAME, so it doesn't matter that\n// the feedback/logging steps dropped the binary along the way.\nconst info    = $('build_ics').first().json;\nconst planMd  = info.report || '';     // the full markdown study plan\nconst icsPath = info.ics_saved;        // path to the .ics already written to disk\n\nconst planBuf = Buffer.from(planMd, 'utf8');\nconst icsBuf  = fs.readFileSync(icsPath);   // read the .ics back from disk\n\nreturn [{\n  json: { bundled: true },\n  binary: {\n    plan: {\n      data: planBuf.toString('base64'),\n      fileName: 'study-plan.md',\n      mimeType: 'text/markdown',\n    },\n    calendar: {\n      data: icsBuf.toString('base64'),\n      fileName: 'study-plan.ics',\n      mimeType: 'text/calendar',\n    },\n  },\n}];"
      },
