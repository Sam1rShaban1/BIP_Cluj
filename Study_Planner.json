      "parameters": {
        "jsCode": "const fs = require('fs');\nconst dir = '/data/flagged';\nfs.mkdirSync(dir, { recursive: true });\nconst report = $json.report || '';\nconst name = (($json.name) || 'student').replace(/[^a-z0-9]+/gi, '_').toLowerCase();\nconst stamp = new Date().toISOString().slice(0,19).replace(/[:T]/g,'-');\nconst path = `${dir}/plan-${name}-${stamp}.md`;\nfs.writeFileSync(path, report);\nreturn [{ json: { saved: path, bytes: report.length, report, name } }];"
      },
