        "jsCode": "const safe = (fn, fb) => { try { return fn(); } catch { return fb; } };\nconst name = safe(() => $('form_data').first().json['Student Name'], 'Student');\nconst plan     = safe(() => $('plan_agent').first().json.output, '');\nconst wellness = safe(() => $('wellness_agent').first().json.output, '');\nconst sustain  = safe(() => $('sustainability_agent').first().json.output, '');\n\nconst report =\n`# Study Plan — ${name}\n\n${plan}\n\n---\n\n## Wellness check\n${wellness}\n\n---\n\n## Sustainability\n${sustain}\n`;\nreturn [{ json: { report, name } }];"
