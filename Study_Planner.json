    {
      "parameters": {
        "jsCode": "const safe = (fn, fb) => { try { return fn(); } catch { return fb; } };\nconst form = () => $('form_data').first();\n\nconst handbookText =\n  safe(() => $('pdf_extractor').first().json.text, '') || '(no handbook provided)';\n\nlet codeText =\n  safe(() => { const j = $('code_extractor').first().json; return j.text ?? j.data; }, '')\n  || '(no source code provided)';\ncodeText = codeText.slice(0, 8000);\n\nconst goal  = safe(() => form().json['Study goal'], '');\nconst level = safe(() => form().json['Your level'], 'Unspecified');\nconst email = safe(() => form().json['Email'], '');\n\n// --- learning preferences (VARK) ---\nconst prefLabels = [\n  'When you take in new information, you learn best by',\n  'You remember new material best when you',\n  'When researching a topic on your own, you prefer to',\n  'Your ideal study session looks like',\n  'When memorising facts or terms, you',\n  \"When following a new procedure, you'd rather\",\n  'To understand how something works, you'\n];\nconst tally = { Visual: 0, Auditory: 0, 'Reading/Writing': 0, Kinesthetic: 0 };\nconst answers = [];\nfor (const label of prefLabels) {\n  const a = safe(() => form().json[label], '');\n  if (!a) continue;\n  answers.push(`- ${label}: ${a}`);\n  const key = a.split('—')[0].trim();\n  if (key in tally) tally[key]++;\n}\nconst max = Math.max(0, ...Object.values(tally));\nconst dominant = max === 0\n  ? 'Unspecified'\n  : Object.keys(tally).filter(k => tally[k] === max).join(' / ');\n\nconst prefsBlock = answers.length\n  ? `Dominant style: ${dominant}\\n${answers.join('\\n')}`\n  : '(no learning preferences provided)';\n\nconst prompt =\n`STUDY GOAL:\n${goal}\n\nSELF-ASSESSED LEVEL: ${level}\n\n=== LEARNING PREFERENCES ===\n${prefsBlock}\n\n=== MODULE HANDBOOK ===\n${handbookText}\n\n=== SOURCE CODE ===\n${codeText}`;\n\nreturn [{ json: { prompt, dominant, email } }];"
      },
