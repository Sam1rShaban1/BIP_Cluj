    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const r = item.json;\n  const comment = String(r.comment || '').trim();\n  const comment_prompt = comment\n    ? `STUDENT COMMENT:\\n\"\"\"${comment}\"\"\"`\n    : 'STUDENT COMMENT:\\n(the student left no comment)';\n  return { json: { ...r, comment_prompt } };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ],
      "id": "b3a73f87-c701-4634-a893-3fd28d8e025a",
      "name": "comment_input"
    },
    {
      "parameters": {
        "jsCode": "function extractJson(raw) {\n  let s = String(raw)\n    .replace(/<\\|?[a-z_]+\\|?>/gi, '')\n    .replace(/```[a-z]*\\n?/gi, '').replace(/```/g, '');\n  const cands = [];\n  for (let i = 0; i < s.length; i++) {\n    if (s[i] !== '{') continue;\n    let depth = 0;\n    for (let j = i; j < s.length; j++) {\n      if (s[j] === '{') depth++;\n      else if (s[j] === '}') { if (--depth === 0) { cands.push(s.slice(i, j + 1)); break; } }\n    }\n  }\n  for (let k = cands.length - 1; k >= 0; k--) { try { return JSON.parse(cands[k]); } catch {} }\n  return null;\n}\n\nconst rows = $('comment_input').all();\nconst analyses = $('Comment Analysis Agent').all();\nconst out = [];\n\nfor (let i = 0; i < rows.length; i++) {\n  const r = rows[i].json;\n  const a = extractJson(analyses[i]?.json?.output ?? analyses[i]?.json?.text ?? '')\n    || { comment_present:false, sentiment:'none', themes:[], specific_issues:'none stated', praise:'none stated', summary:'none stated' };\n\n  const judgePrompt =\n`INPUTS (study goal, self-assessed level, handbook, learning preferences, source code)\n${r.inputs}\n\nSTUDENT RATING (1-5, given by the human student): ${r.rating}\n\nSTUDENT COMMENT ANALYSIS:\n- sentiment: ${a.sentiment}\n- themes: ${(a.themes || []).join(', ') || 'none'}\n- issues raised: ${a.specific_issues}\n- praise: ${a.praise}\n- summary: ${a.summary}\n\nPLAN\n${r.plan}`;\n\n  out.push({ json: {\n    feedback_id: r.feedback_id,\n    student: r.student,\n    rating: r.rating,        // carried untouched\n    _analysis: a,\n    judgePrompt\n  }});\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1024,
        0
      ],
      "id": "c784d732-a7df-440c-ad71-c13c8504ff81",
      "name": "judge_input"
    },
    {
      "parameters": {
        "jsCode": "function extractJson(raw) {\n  let s = String(raw)\n    .replace(/<\\|?[a-z_]+\\|?>/gi, '')\n    .replace(/```[a-z]*\\n?/gi, '').replace(/```/g, '');\n  const cands = [];\n  for (let i = 0; i < s.length; i++) {\n    if (s[i] !== '{') continue;\n    let depth = 0;\n    for (let j = i; j < s.length; j++) {\n      if (s[j] === '{') depth++;\n      else if (s[j] === '}') { if (--depth === 0) { cands.push(s.slice(i, j + 1)); break; } }\n    }\n  }\n  for (let k = cands.length - 1; k >= 0; k--) { try { return JSON.parse(cands[k]); } catch {} }\n  return null;\n}\n\nconst meta = $('judge_input').all();\nconst judged = $('Judge Agent').all();\nconst out = [];\n\nfor (let i = 0; i < judged.length; i++) {\n  const m = meta[i].json;\n  const a = m._analysis || {};\n  const s = extractJson(judged[i].json.output ?? judged[i].json.text ?? '')\n    || { grounding:0, calibration:0, actionability:0, honesty:0, overall:0, notes:'PARSE_FAILED' };\n\n  out.push({ json: {\n    feedback_id: m.feedback_id,\n    evaluated_at: new Date().toISOString(),\n    student: m.student,\n    student_rating: m.rating,                       // human rating, untouched\n    comment_present: !!a.comment_present,\n    comment_sentiment: a.sentiment || 'none',\n    comment_themes: (a.themes || []).join('; '),\n    comment_summary: a.summary || 'none stated',\n    grounding: Number(s.grounding) || 0,\n    calibration: Number(s.calibration) || 0,\n    actionability: Number(s.actionability) || 0,\n    honesty: Number(s.honesty) || 0,\n    overall: Number(s.overall) || 0,\n    notes: String(s.notes || '')\n  }});\n}\nreturn out;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
